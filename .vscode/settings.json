{
  "[typescript]": {
    "editor.defaultFormatter": "oxc.oxc-vscode"
  },
  "[typescriptreact]": {
    "editor.defaultFormatter": "oxc.oxc-vscode"
  },
  "css.customData": [
    ".vscode/css-data.json"
  ],
  // "editor.codeActionsOnSave": [
  //   // only sort imports
  //   "source.sortImports",
  //   // remove unused imports & sort imports
  //   // "source.organizeImports",
  //   // "source.fixAll.eslint",
  // ],
  "eslint.format.enable": false,
  "js/ts.preferences.autoImportSpecifierExcludeRegexes": [
    "^node:console$",
    "^typescript$",
    "^zod/locales",
    "^zod/v4/locales",
  ],
  "prettier.enable": true,
  "tailwindCSS.experimental.configFile": "src/styles/tailwind.css"
}